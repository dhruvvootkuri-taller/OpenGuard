# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- API authentication ----
# Comma-separated list of accepted API keys / bearer tokens. Protected,
# state-changing and call-placing endpoints (POST /api/events,
# POST /api/feeds/.../frame, POST /api/voice/calls, acknowledge/resolve/
# dismiss/clear-resolved) require one of these via either header:
#   Authorization: Bearer <key>     or     X-API-Key: <key>
# SECURITY: if this is unset/empty, the auth layer FAILS CLOSED and denies
# every protected request (401). Generate strong random keys, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OPEN_GUARD_API_KEYS=

# ---- Event lifecycle ----
# Active events with no new frames/detections for this many seconds are
# auto-resolved (auto-expired) so the dashboard reflects current activity.
# Set to 0 to disable auto-expiry. Default: 300 (5 minutes).
EVENT_INACTIVITY_TTL_SECONDS=300

# ---- Emergency de-duplication ----
# Repeated emergency frames from the same camera within this window (seconds)
# are collapsed into ONE incident: one SecurityEvent, one escalation call.
# A new incident is allowed after the window elapses or the event is acked.
EMERGENCY_DEDUP_WINDOW_SECONDS=60

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
# ---- Celery (background task queue, Redis-backed) ----
# Defaults to REDIS_URL for the broker and DB 1 for the result backend.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- Anthropic / Claude Haiku (escalation reasoning) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-haiku-20240307
# ---- Anthropic / Claude vision (MP4 feed-frame analysis) ----
# Each captured MP4 frame is assessed by this model. Must be a CURRENT vision
# model: claude-3-5-sonnet-20241022 was retired 2025-10-28 and 404s every frame.
ANTHROPIC_VISION_MODEL=claude-opus-4-8

# ---- ElevenLabs (voice synthesis) ----
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=Rachel
# ---- ElevenLabs Conversational AI (interactive voice agent over Twilio) ----
# Provisioned once: create an agent + import the Twilio number in ElevenLabs.
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxx
ELEVENLABS_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxx

# ---- Twilio (calls / SMS) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15555550100
ON_CALL_NUMBER=+15555550199

# ---- Detection gating (cut false alarms) ----
# A frame the vision model flags must clear BOTH thresholds below to count as a
# real candidate. Anything weaker is surfaced as a low-severity candidate only —
# never an event, never a call.
DETECTION_MIN_CONFIDENCE=0.6
DETECTION_MIN_THREAT_SCORE=0.4
# Multi-frame confirmation: the SAME emergency on the SAME camera must appear in
# at least DETECTION_CONFIRMATION_REQUIRED of the last DETECTION_CONFIRMATION_WINDOW
# flagged frames before a SecurityEvent is created and escalation is enqueued.
DETECTION_CONFIRMATION_WINDOW=3
DETECTION_CONFIRMATION_REQUIRED=2

# ---- Vision cost controls / rate limiting ----
# Guard Anthropic spend + DoS on POST /api/feeds/{camera_id}/frame. Each limit
# is enforced server-side BEFORE the vision call; set any to 0 to disable it.
# Per-camera minimum interval (seconds) between ANALYSED frames; frames arriving
# faster are skipped (returned as throttled, not analysed).
VISION_PER_CAMERA_MIN_INTERVAL_SECONDS=2.0
# Global cap on concurrent in-flight vision calls across all cameras.
VISION_MAX_CONCURRENT_CALLS=4
# Global cap on vision calls per rolling minute across all cameras.
VISION_MAX_CALLS_PER_MINUTE=60
# Daily budget: once this many vision calls are made the kill switch halts ALL
# analysis until UTC midnight; the throttled response surfaces the state.
VISION_DAILY_BUDGET_CALLS=5000
# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- Event lifecycle ----
# Active events with no new frames/detections for this many seconds are
# auto-resolved (auto-expired) so the dashboard reflects current activity.
# Set to 0 to disable auto-expiry. Default: 300 (5 minutes).
EVENT_INACTIVITY_TTL_SECONDS=300

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Celery (background task queue, Redis-backed) ----
# Defaults to REDIS_URL for the broker and DB 1 for the result backend.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- Anthropic / Claude Haiku (escalation reasoning) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-haiku-20240307
# ---- Anthropic / Claude vision (MP4 feed-frame analysis) ----
# Each captured MP4 frame is assessed by this model. Must be a CURRENT vision
# model: claude-3-5-sonnet-20241022 was retired 2025-10-28 and 404s every frame.
ANTHROPIC_VISION_MODEL=claude-opus-4-8

# ---- ElevenLabs (voice synthesis) ----
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=Rachel
# ---- ElevenLabs Conversational AI (interactive voice agent over Twilio) ----
# Provisioned once: create an agent + import the Twilio number in ElevenLabs.
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxx
ELEVENLABS_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxx

# ---- Twilio (calls / SMS) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15555550100
ON_CALL_NUMBER=+15555550199

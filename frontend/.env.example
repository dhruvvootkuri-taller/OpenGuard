# Base URL for the Open Guard API (leave empty to use the Vite dev proxy)
VITE_API_BASE_URL=
# API key sent on protected (state-changing) requests so the dashboard passes
# the backend auth layer. Must match one of the backend's OPEN_GUARD_API_KEYS.
# Leave empty only for local dev where the backend runs with auth unconfigured.
VITE_OPEN_GUARD_API_KEY=
